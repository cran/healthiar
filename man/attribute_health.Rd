\itemize{
 \item \code{approach_risk}
 \item \code{exp_central}, \code{exp_lower}, \code{exp_upper}
 \item \code{cutoff_central}, \code{cutoff_lower}, \code{cutoff_upper}
 \item \code{erf_eq_central}, \code{erf_eq_lower}, \code{erf_eq_upper}
